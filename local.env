# ==========================================
# CLIPFLOW ENVIRONMENT VARIABLES TEMPLATE
# ==========================================

# 1. DATABASE (Neon Serverless Postgres)
DATABASE_URL="postgres://username:password@your-neon-hostname.neon.tech/dbname?sslmode=require"

# 2. AUTHENTICATION (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_clerk_publishable_key"
CLERK_SECRET_KEY="sk_test_your_clerk_secret_key"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# 3. GOOGLE PLATFORM (YouTube & Google Drive)
# Note: Since you are using the same Google Console App, paste the exact same
# Client ID and Client Secret into both sections below.
YOUTUBE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
YOUTUBE_CLIENT_SECRET="your-client-secret"
NEXT_PUBLIC_YOUTUBE_REDIRECT_URI="http://localhost:3000/api/auth/youtube/callback"

DRIVE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
DRIVE_CLIENT_SECRET="your-client-secret"
NEXT_PUBLIC_DRIVE_REDIRECT_URI="http://localhost:3000/api/auth/drive/callback"

# 4. STORAGE (Cloudflare R2 - Zero Egress)
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key"
R2_SECRET_ACCESS_KEY="your_r2_secret_key"
R2_BUCKET_NAME="clipflow-uploads"

# 5. GENERAL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
